{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=grammarai;Username=grammarai;Password=secret"
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_TO_A_RANDOM_32_CHAR_SECRET",
    "Issuer": "grammarai-api",
    "Audience": "grammarai-clients",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "30"
  },
  "TelegramBot": {
    "Token": "YOUR_BOT_TOKEN_HERE",
    "WebhookUrl": "https://your-domain.com"
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "Model": "gpt-4o"
  },
  "Storage": {
    "Endpoint": "https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com",
    "AccessKey": "YOUR_R2_ACCESS_KEY",
    "SecretKey": "YOUR_R2_SECRET_KEY",
    "BucketName": "grammarai",
    "PublicBaseUrl": "https://pub.your-domain.com"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Cors": {
    "Origins": "http://localhost:3000,https://your-frontend-domain.com"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*"
}
